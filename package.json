{
	"type": "module",
	"scripts": {
		"start": "eleventy --config=eleventy.config.ts --serve",
		"build": "eleventy --config=eleventy.config.ts",
		"build:aseprite": "git clone https://github.com/cubeghost/node-aseprite && cd node-aseprite && pnpm --ignore-workspace install && node ./build.js && cd .. && pnpm link ./node-aseprite"
	},
	"dependencies": {
		"11ty.ts": "^0.0.7",
		"@11ty/eleventy": "^3.1.5",
		"@11ty/eleventy-img": "^6.0.4",
		"@11ty/eleventy-plugin-rss": "^3.0.0",
		"@11ty/eleventy-plugin-webc": "^0.11.2",
		"@cornerstonejs/codec-libjpeg-turbo-8bit": "^1.2.2",
		"@netlify/blobs": "^10.7.7",
		"@netlify/functions": "^5.2.1",
		"@upstash/redis": "^1.38.0",
		"aseprite": "github:cubeghost/node-aseprite",
		"canvas": "^3.2.3",
		"canvas-dither": "^1.0.1",
		"d3": "^7.9.0",
		"d3-array": "^3.2.4",
		"d3-hierarchy": "^3.1.2",
		"d3-random": "^3.0.1",
		"esbuild-plugin-import-map": "^2.1.0",
		"farmhash": "^5.0.1",
		"gifenc": "^1.0.3",
		"gifuct-js": "^2.1.2",
		"isbot": "^5.1.44"
	},
	"devDependencies": {
		"@types/11ty__eleventy-img": "^4.0.0",
		"@types/d3": "^7.4.3",
		"@types/d3-hierarchy": "^3.1.7",
		"@types/esbuild-plugin-import-map": "^0.0.3",
		"@types/gif-encoder": "^0.7.4",
		"@types/node": "^25.8.0",
		"eleventy-plugin-console-plus": "^2.0.0",
		"esbuild": "^0.28.0",
		"tsx": "^4.22.1"
	},
	"packageManager": "pnpm@10.33.0",
	"pnpm": {
		"overrides": {
			"canvas": "^3.2.3",
			"aseprite": "link:node-aseprite"
		}
	}
}