---json
{
  "permalink": "feed.xml",
  "layout": false,
  "eleventyExcludeFromCollections": true,
  "eleventyImport": {
    "collections": ["all"]
  },
  "metadata": {
    "title": "cubegho.st",
    "description": "alex got their homepage at cubegho.st",
    "language": "en",
    "author": {
      "name": "alex"
    }
  }
}
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="{{ metadata.language }}">
  <title>{{ metadata.title }}</title>
  <subtitle>{{ metadata.description }}</subtitle>
  <link href="{{ permalink | htmlBaseUrl: site.url }}" rel="self" />
  <link href="{{ site.url | addPathPrefixToFullUrl }}" />
  <updated>{{ collections.all | getNewestCollectionItemDate | dateToRfc3339 }}</updated>
  <id>{{ site.url | addPathPrefixToFullUrl }}</id>
  <author>
    <name>{{ metadata.author.name }}</name>
  </author>
  {%- for post in collections.all | reverse %}
  {%- if post.data.permalink != false or post.data.date -%}
  {%- liquid
    if post.data.permalink == false
      assign absolutePostUrl = post.data.url
    else
      assign absolutePostUrl = post.url | htmlBaseUrl: site.url
    endif
  -%}
  <entry>
    <title>{{ post.data.title }}</title>
    <link href="{{ absolutePostUrl }}" />
    <updated>{{ post.date | dateToRfc3339 }}</updated>
    <id>{{ absolutePostUrl }}</id>
    {%- if post.data.description -%}
    {%- capture content -%}
      {%- if post.data.preview -%}
      <img src="{{ post.data.preview.src }}" alt="{{ post.data.preview.alt }}" />
      {%- endif -%}
      <p>{{ post.data.description }}</p>
    {%- endcapture -%}
    {%- elsif post.content.length > 0 -%}
    {%- assign content = post.content -%}
    {%- elsif post.data.images -%}
    {%- capture content -%}
      {%- for image in post.data.images %}
      <figure>
        <img src="{{ image.src }}" alt="{{ image.alt }}" />
        {% if image.caption %}
        <figcaption>{{ image.caption }}</figcaption>
        {% endif %}
      </figure>
      {% endfor -%}
    {% endcapture %}
    {%- elsif post.data.preview -%}
    {%- capture content -%}
      <img src="{{ post.data.preview.src }}" alt="{{ post.data.preview.alt }}" />
    {%- endcapture -%}
    {%- else -%}
    {% assign content = nil %}
    {%- endif -%}

    {%- if content -%}
    <content type="html">
      {{ content | renderTransforms: post.data.page, site.url | escape }}
    </content>
    {%- else -%}
    <content type="html" />
    {%- endif -%}
  </entry>
  {%- endif -%}
  {%- endfor %}
</feed>