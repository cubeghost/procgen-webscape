{%- capture props %}
{
  "src": "{{ src }}",
  "alt": "{{ alt | escape_once }}",
  "play_gif": {% if play_gif == nil %}true{% else %}{{ play_gif }}{% endif %}
  {% if width %}, "width": "{{ width }}"{% endif %}
  {% if class %}, "class": "{{ class }}"{% endif %}
  {% if id %}, "id": "{{ id }}"{% endif %}
  {% if style %}, "style": "{{ style | escape_once }}"{% endif %}
}
{% endcapture -%}
{%- assign props = props | json_parse -%}
{% retina_image props %}