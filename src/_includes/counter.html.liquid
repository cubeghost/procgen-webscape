<iframe src="/.netlify/functions/counter{% if align %}?align={{ align }}{% endif %}" class="visitors" id="counter"></iframe>
<script type="text/javascript">
  document.getElementById("counter").addEventListener("load", (event) => {
    const counterWindow = document.getElementById("counter").contentWindow.document.querySelector(".visitors-container");
    if (counterWindow) document.body.style.setProperty("--counter-width", `${counterWindow.offsetWidth}px`);
  })
</script>