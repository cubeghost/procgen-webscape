{%- capture sprites -%}
  [
    "system",
    "system-open",
    "stickies",
    "notepad",
    "globe",
    "resedit",
    "resedit-open",
    "document-code",
    "document-macpaint",
    "folder"
  ]
{%- endcapture -%}
{%- assign sprites = sprites | json_parse -%}
{%- assign sprite_index = sprites | find_index_value: id -%}
{%- if position_only -%}
{{ sprite_index | times: -32 }}px 0
{%- else -%}
<img 
  src="/assets/icons-32.png"
  {% if role != "presentation" -%}
  alt="{{ alt }}"
  {%- endif %}
  class="sprite sprite-32"
  style="object-position: {{ sprite_index | times: -32 }}px 0; {{ style | default: "" }}"
  {% if role -%}
  role="{{ role }}"
  {%- endif %}
  eleventy:ignore 
/>
{% endif %}