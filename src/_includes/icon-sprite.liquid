{%- liquid
  if size == 16
    assign sprites = icons16
  elsif size == 32
    assign sprites = icons32
  endif
-%}
{%- assign sprite_index = sprites | find_index_value: id -%}
{%- assign multiplier = size | times: -1 -%}
{%- if position_only -%}
{{ sprite_index | times: multiplier }}px 0
{%- else -%}
<img 
  src="/assets/icons-{{ size }}.png"
  {% if role != "presentation" -%}
  alt="{{ alt }}"
  {%- endif %}
  class="sprite sprite-{{ size }}"
  style="object-position: {{ sprite_index | times: multiplier }}px 0; {{ style | default: "" }}"
  {% if role -%}
  role="{{ role }}"
  {%- endif %}
  eleventy:ignore 
/>
{% endif %}