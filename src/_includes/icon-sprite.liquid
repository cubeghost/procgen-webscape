{%- capture sprites -%}
  [
    "looped-square",
    "sheep",
    "baby-sheep",
    "nodepad",
    "help",
    "hypercard-stack",
    "hypercard",
    "alert-text",
    "document-preferences",
    "document-code",
    "document-text",
    "simpletext",
    "git",
    "mail1",
    "suitcase-git",
    "suitcase",
    "scrapbook",
    "globe",
    "pause",
    "play"
  ]
{%- endcapture -%}
{%- assign sprites = sprites | json_parse -%}
{%- assign sprite_index = sprites | find_index_value: id -%}
{%- if position_only -%}
{{ sprite_index | times: -16 }}px 0
{%- else -%}
<img 
  src="/assets/icons.png"
  {% if role != "presentation" -%}
  alt="{{ alt }}"
  {%- endif %}
  class="sprite"
  style="object-position: {{ sprite_index | times: -16 }}px 0; {{ style | default: "" }}"
  {% if role -%}
  role="{{ role }}"
  {%- endif %}
  eleventy:ignore 
/>
{% endif %}